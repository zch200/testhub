# TestHub 环境变量配置
# 复制此文件为 .env 后按需修改

# 服务监听地址（默认 127.0.0.1，仅本机访问）
# HOST=127.0.0.1

# 服务监听端口（默认 4010）
# PORT=4010

# SQLite 数据库文件路径（默认 apps/server/data/testhub.db）
# 开发时建议指向独立文件，避免污染正式数据
# TESTHUB_DB_PATH=dev.db

# 固定 API Token（不设置则自动生成并持久化到 apps/server/data/api-token）
# TESTHUB_API_TOKEN=your_token_here

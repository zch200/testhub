{
  "name": "testhub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "pnpm --filter @testhub/server start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @testhub/server db:generate",
    "db:migrate": "pnpm --filter @testhub/server db:migrate",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "pnpm --filter @testhub/server test:watch",
    "build:cli": "turbo run build --filter=@testhub/web --filter=@testhub/shared && pnpm --filter testhub-app run build",
    "publish:cli": "pnpm build:cli && pnpm --filter testhub-app publish"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}